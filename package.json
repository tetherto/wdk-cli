{
  "name": "wdk-cli",
  "version": "0.0.1",
  "description": "CLI tool for Wallet Development Kit (WDK)",
  "type": "module",
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "wdk.config.json"
  ],
  "bin": {
    "wdk": "./bin/wdk.mjs",
    "wdk-mcp": "./bin/wdk-mcp.mjs",
    "wdk-daemon": "./bin/wdk-daemon.mjs"
  },
  "scripts": {
    "postinstall": "node scripts/install-wallets.mjs",
    "install-wallets": "node scripts/install-wallets.mjs",
    "format": "prettier --write src/ tests/ bin/ scripts/",
    "format:check": "prettier --check src/ tests/ bin/ scripts/",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "test": "node --test --experimental-test-module-mocks --disable-warning=ExperimentalWarning tests/unit/",
    "test:integration": "node --test --test-timeout=60000 --disable-warning=ExperimentalWarning tests/integration/"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@inquirer/prompts": "8.2.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tetherto/wdk": "1.0.0-beta.6",
    "@tetherto/wdk-protocol-fiat-moonpay": "1.0.0-beta.2",
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "bignumber.js": "11.1.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "conf": "15.1.0",
    "ora": "9.3.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "3.3.3",
    "typescript": "^5.8.3"
  }
}
