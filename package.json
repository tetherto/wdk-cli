{
  "name": "wdk-cli",
  "version": "0.0.1",
  "description": "CLI tool for Wallet Development Kit (WDK)",
  "type": "module",
  "files": [
    "bin/",
    "dist/"
  ],
  "bin": {
    "wdk": "./bin/wdk.mjs",
    "wdk-mcp": "./bin/wdk-mcp.mjs",
    "wdk-daemon": "./bin/wdk-daemon.mjs"
  },
  "scripts": {
    "postinstall": "node scripts/install-wallets.mjs",
    "install-wallets": "node scripts/install-wallets.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration --testTimeout=60000"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@inquirer/prompts": "8.2.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tetherto/wdk": "1.0.0-beta.6",
    "@tetherto/wdk-protocol-fiat-moonpay": "1.0.0-beta.2",
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "bignumber.js": "11.1.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "conf": "15.1.0",
    "ora": "9.3.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.11",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "eslint": "9.39.2",
    "tsdown": "0.21.10",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vitest": "3.2.4"
  }
}
